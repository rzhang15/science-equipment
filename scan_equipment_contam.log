. do /tmp/scan_equipment_contam.do 

. set more off

. clear all

. cd /n/holylabs/pakes_lab/Lab/sci_eq/derived/first_stage/make_mkt_panel/output
/n/holylabs/pakes_lab/Lab/sci_eq/derived/first_stage/make_mkt_panel/output

. 
. use full_item_level_tfidf, clear

. 
. * Flag items whose desc contains common equipment/machine words
. * (deliberately broad, then we'll see which categories get hit a lot)
. gen flag_equip = 0

. foreach w in "machine" "instrument" "analyzer" "detector" "imager" "scanner" 
> ///
>              "centrifuge" "shaker" "stirrer" "balance" "scale" "freezer" ///
>              "refrigerator" "fridge" "thermomixer" "vortex" "sonicator" ///
>              "microscope" "camera" "printer" "computer" "laptop" ///
>              "pump" "valve" "regulator" "controller" "transformer" ///
>              "heater" "cooler" "tank" "cylinder" "manifold" "station" ///
>              "workstation" "system unit" "unit pkg" "device" "kit assembly" /
> //
>              "filtration unit" "sensor" "probe" "electrode" "module" {
  2.     qui replace flag_equip = 1 if strpos(clean_desc, "`w'") > 0
  3. }

. 
. * drop already-equipment-loaded categories so we don't double-count those
. gen flag_chemicals = strpos(category, "chemicals") > 0

. 
. di "----- categories ranked by share of items flagged as equipment-y -----"
----- categories ranked by share of items flagged as equipment-y -----

. preserve

