. do /tmp/diag3.do 

. set more off

. use output/cleaned_merged_fois, clear

. keep if year <= 2013
(160,964 observations deleted)

. keep if keep == 1
(15,234 observations deleted)

. merge m:1 athr_id using output/foia_athrs_with_clusters_10, assert(1 2 3) kee
> p(3) nogen

    Result                      Number of obs
    -----------------------------------------
    Not matched                             0
    Matched                            47,290  
    -----------------------------------------

. gcollapse (sum) spend (mean) treated cluster_label, by(athr_id category)

. bys athr_id: egen tot_lab_spend = total(spend)

. gen lab_spend_shr = spend / tot_lab_spend
(12 missing values generated)

. merge m:1 category using external/betas/did_coefs, keep(1 3)

    Result                      Number of obs
    -----------------------------------------
    Not matched                         6,154
        from master                     6,154  (_merge==1)
        from using                          0  (_merge==2)

    Matched                             1,155  (_merge==3)
    -----------------------------------------

. gen has_beta = (_merge == 3)

. drop _merge

. 
. * current measure
. gen exposure_current = b * lab_spend_shr
(6,157 missing values generated)

. * alternative: restrict denominator to beta-having spend
. bys athr_id: egen tot_beta_spend = total(spend) if has_beta == 1
(6,154 missing values generated)

. bys athr_id: egen tot_beta_spend_max = max(tot_beta_spend)
(370 missing values generated)

. gen lab_spend_shr_beta = spend / tot_beta_spend_max if has_beta == 1
(6,160 missing values generated)

. gen exposure_restricted = b * lab_spend_shr_beta
(6,160 missing values generated)

. 
. collapse (sum) exposure_current exposure_restricted spend (max) tot_beta_spen
> d_max, by(athr_id treated)

. gen beta_share = tot_beta_spend_max / spend
(61 missing values generated)

. replace beta_share = 0 if mi(tot_beta_spend_max)
(57 real changes made)

. 
. drop if mi(exposure_current)
(0 observations deleted)

