(15,234 observations deleted)

. qui sum spend

. local total = r(sum)

. qui sum spend if tier3 == 1

. di "tier3==1 share of denom: " r(sum)/`total'*100 "%   spend=" r(sum)
tier3==1 share of denom: 1.1349443%   spend=61958.34

. qui sum spend if tier3 == 0

. di "tier3==0 share of denom: " r(sum)/`total'*100 "%   spend=" r(sum)
