. do "/tmp/diag_merge.do" 

. set more off

. clear all

. use ../external/foia/merged_foias_with_pis, clear

. keep if !mi(athr_id)
(62,139 observations deleted)

. gen year = year(date(date, "YMD"))

. keep if inrange(year, 2010, 2019)
(44,336 observations deleted)

. replace predicted_market = category if inlist(uni, "utdallas", "umich")
(97,941 real changes made)

. drop category

. rename predicted_market category

. preserve

. contract category

. keep category

. save /tmp/cats_master, replace
(file /tmp/cats_master.dta not found)
file /tmp/cats_master.dta saved

. restore

. use ../external/ml/categories_tfidf, clear

. keep category

. gen in_tfidf = 1

. save /tmp/cats_tfidf, replace
(file /tmp/cats_tfidf.dta not found)
file /tmp/cats_tfidf.dta saved

. use /tmp/cats_master, clear

