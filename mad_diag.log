. do /tmp/mad_diag.do 

. set more off

. clear all

. use /n/holylabs/pakes_lab/Lab/sci_eq/derived/first_stage/make_mkt_panel/outpu
> t/full_item_level_tfidf.dta, clear

. // reconstruct what the MAD filter saw using the same anchors as the new code
. gen lp = log(raw_price)

. bys category: gegen med_lp_cat = median(lp)

. bys category year: gegen med_lp_yr_raw = median(lp)

. gen med_lp_yr = cond(abs(med_lp_yr_raw - med_lp_cat) > ln(2), med_lp_cat, med
> _lp_yr_raw)

. gen abs_dev = abs(lp - med_lp_yr)

. bys category year: gegen mad = median(abs_dev)

. gen cap_a = 3 * mad

. gen cap_b = log(3)

. gen used_cap = min(cap_a, cap_b)

. gen would_drop_cap3 = abs_dev > min(3*mad, log(3)) & mad > 0

. gen would_drop_no_cap = abs_dev > 3*mad & mad > 0

. gen would_drop_cap5 = abs_dev > min(3*mad, log(5)) & mad > 0

. gen would_drop_cap10 = abs_dev > min(3*mad, log(10)) & mad > 0

. di " "
 

. di "MAD distribution across category-years (in log price units)"
MAD distribution across category-years (in log price units)

