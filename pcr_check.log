. do /tmp/pcr_check.do 

. set more off

. clear all

. cd /n/holylabs/pakes_lab/Lab/sci_eq/derived/first_stage/make_mkt_panel/output
/n/holylabs/pakes_lab/Lab/sci_eq/derived/first_stage/make_mkt_panel/output

. 
. * find categories matching pcr/amplification
. use full_item_level_tfidf, clear

. gen flag = strpos(category, "pcr") > 0 | strpos(category, "amplif") > 0

. levelsof category if flag, local(cats)
`"column-based pcr and gel purification kit"' `"column-based pcr purification k
> its"' `"ddpcr systems"' `"direct pcr lysis reagents"' `"dye-based qpcr system
> s"' `"genome amplification kits"' `"high-fidelity hot start pcr systems"' `"h
> igh-fidelity pcr systems"' `"hot start pcr systems"' `"long template pcr syst
> ems"' `"pcr systems"' `"pcr tube strips"' `"pcr tubes"' `"pre amplification k
> its"' `"pre-designed qpcr assays"' `"probe-based qpcr systems"' `"probe-based
>  rt-qpcr systems"' `"qpcr reaction dyes"' `"tissue pcr systems"'

. di "Matching cats:"
Matching cats:

. foreach c in `cats' {
  2.     di "  - `c'"
  3. }
  - column-based pcr and gel purification kit
  - column-based pcr purification kits
  - ddpcr systems
  - direct pcr lysis reagents
  - dye-based qpcr systems
  - genome amplification kits
  - high-fidelity hot start pcr systems
  - high-fidelity pcr systems
  - hot start pcr systems
  - long template pcr systems
  - pcr systems
  - pcr tube strips
  - pcr tubes
  - pre amplification kits
  - pre-designed qpcr assays
  - probe-based qpcr systems
  - probe-based rt-qpcr systems
  - qpcr reaction dyes
  - tissue pcr systems

. 
. foreach c in `cats' {
  2.     di _newline _newline "================================================
> ==="
  3.     di "CATEGORY: `c'"
  4.     di "==================================================="
  5.     use full_item_level_tfidf if category == "`c'", clear
  6.     qui count
  7.     di "N items = " r(N)
  8.     
.     di "----- yearly aggregates -----"
  9.     preserve
 10.     gcollapse (count) n=raw_price (mean) mean_price=raw_price (sum) tot_sp
> end=raw_spend tot_qty=raw_qty (median) med_price=raw_price (firstnm) precisio
> n recall support, by(year)
 11.     list year n mean_price med_price tot_qty tot_spend, sep(0) noobs
 12.     di "precision/recall/support (constant):"
 13.     list precision recall support in 1, sep(0) noobs
 14.     restore
 15.     
.     di "----- top 5 suppliers by spend -----"
 16.     preserve
 17.     gcollapse (sum) raw_spend (count) n=raw_spend, by(suppliername)
 18.     gsort -raw_spend
 19.     qui keep if _n <= 5
 20.     list suppliername n raw_spend, sep(0) noobs ab(40)
 21.     restore
 22.     
.     di "----- top 5 priciest items 2010-2011 -----"
 23.     preserve
 24.     keep if inrange(year, 2010, 2011)
 25.     gsort -raw_price
 26.     qui keep if _n <= 5
 27.     list clean_desc suppliername raw_price raw_qty raw_spend year, sep(0) 
> noobs ab(60)
 28.     restore
 29.     
.     di "----- top 5 priciest items 2018-2019 -----"
 30.     preserve
 31.     keep if inrange(year, 2018, 2019)
 32.     gsort -raw_price
 33.     qui keep if _n <= 5
 34.     list clean_desc suppliername raw_price raw_qty raw_spend year, sep(0) 
> noobs ab(60)
 35.     restore
 36.     
.     di "----- 5 random items from 2013 (base year) -----"
 37.     preserve
 38.     keep if year == 2013
 39.     qui count
 40.     if r(N) >= 5 sample 5, count
 41.     list clean_desc raw_price raw_qty, sep(0) noobs ab(70)
 42.     restore
 43. }


