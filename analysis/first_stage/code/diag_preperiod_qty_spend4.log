. 
. * ------------------------------------------------------------------
. * Drill into us fbs item-level data
. * ------------------------------------------------------------------
. 
. local susp_cats `" "us fbs" "nitrocellulose blotting membranes" "column-based
>  dna plasmid miniprep" "nucleic acid gel stains" "phosphate-buffered saline (
> pbs) buffer" "'

. 
. foreach c of local susp_cats {
  2.     di " "
  3.     di "==================================================================
> "
  4.     di "CATEGORY: `c'"
  5.     di "==================================================================
> "
  6. 
.     * (a) year-level summary
.     use ../external/samp/full_item_level_tfidf, clear
  7.     keep if treated == 1 & category == "`c'"
  8.     di "  -- (a) Year-level summary --"
  9.     tabstat raw_qty raw_spend , by(year) stat(sum mean N) format(%12.2f)
 10. 
.     * (b) supplier x year qty totals - top 15 by 2010 qty
.     use ../external/samp/full_item_level_tfidf, clear
 11.     keep if treated == 1 & category == "`c'"
 12.     keep if inlist(year, 2010, 2011, 2013, 2017)
 13.     collapse (sum) raw_qty raw_spend (count) n_obs = raw_qty, by(suppliern
> ame year)
 14.     reshape wide raw_qty raw_spend n_obs, i(suppliername) j(year)
 15.     foreach v of varlist raw_qty* raw_spend* n_obs* {
 16.         replace `v' = 0 if mi(`v')
 17.     }
 18.     gsort -raw_qty2010
 19.     di " "
 20.     di "  -- (b) Top suppliers by 2010 qty (qty / spend / N obs by year) -
> -"
 21.     list suppliername raw_qty2010 raw_qty2011 raw_qty2013 raw_qty2017 ///
>         n_obs2010 n_obs2011 n_obs2013 n_obs2017 in 1/12, noobs sep(0) ab(15)
 22. 
.     * (c) top 20 items by spend in 2010-2011
.     use ../external/samp/full_item_level_tfidf, clear
 23.     keep if treated == 1 & category == "`c'"
 24.     keep if inlist(year, 2010, 2011)
 25.     gsort -raw_spend
 26.     di " "
 27.     di "  -- (c) Top 20 items by spend in 2010-2011 --"
 28.     list year suppliername agencyname clean_desc raw_qty raw_price raw_spe
> nd similarity_score in 1/20, noobs sep(0) ab(40)
 29. 
.     * (d) top 20 items by qty in 2010-2011
.     use ../external/samp/full_item_level_tfidf, clear
 30.     keep if treated == 1 & category == "`c'"
 31.     keep if inlist(year, 2010, 2011)
 32.     gsort -raw_qty
 33.     di " "
 34.     di "  -- (d) Top 20 items by qty in 2010-2011 --"
 35.     list year suppliername agencyname clean_desc raw_qty raw_price raw_spe
> nd similarity_score in 1/20, noobs sep(0) ab(40)
 36. 
.     * (e) drop top-N obs by raw_qty in 2010-2011 and measure impact on mean l
> og_qty[2010] - mean log_qty[2013]
.     di " "
 37.     di "  -- (e) Drop top-N pre items, recompute mean(log_qty[2010]) - mea
> n(log_qty[2013]) --"
 38.     foreach n of numlist 0 1 5 10 20 50 100 {
 39.         use ../external/samp/full_item_level_tfidf, clear
 40.         qui keep if treated == 1 & category == "`c'"
 41.         qui gen ln_q = ln(raw_qty)
 42.         qui gsort year -raw_qty
 43.         qui bys year: gen rk = _n
 44.         qui drop if inlist(year, 2010, 2011) & rk <= `n'
 45.         qui sum ln_q if year == 2013
 46.         local m2013 = r(mean)
 47.         qui sum ln_q if year == 2010
 48.         local d2010 = r(mean) - `m2013'
 49.         qui sum ln_q if year == 2011
 50.         local d2011 = r(mean) - `m2013'
 51.         di as txt "    n_dropped = " %3.0f `n' "   d_log_qty[2010] = " %7.
> 4f `d2010' "   d_log_qty[2011] = " %7.4f `d2011'
 52.     }
 53. }
 
