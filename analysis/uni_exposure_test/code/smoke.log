. // -----------------------------------------------------------------------------
. // build_panel: construct the university-by-year analysis panel.
. //   - exposure_j = sum_{m in treated, high-conf} s_jm * b_eb_m
. //   - s_treat_j  = sum_{m in treated, high-conf} s_jm  (overall treated share)
. //   - s_jm: uni j's pre-2013 spend in market m as share of pre-2013 spend
. //           across all high-confidence markets (treated + control).
. //   - outcomes summed over high-confidence markets only:
. //       ctrl_spend_jt, ctrl_qty_jt, treat_spend_jt, tot_spend_jt
. //   - sample: unis with positive pre-2013 spend in both treated and control
. //             high-conf markets, observed both before and after 2014.
. // -----------------------------------------------------------------------------
. program build_panel
  1.     use ../external/samp/full_uni_category_yr_tfidf, clear
  2.     keep if keep == 1                           // high-confidence markets only
  3.     keep category year uni_id treated raw_spend raw_qty
  4. 
.     // --- pre-2013 shares and exposure -----------------------------------------
.     preserve
  5.     keep if year <= 2013
  6.     gcollapse (sum) raw_spend, by(uni_id category treated)
  7.     bys uni_id: egen tot_pre_spend = total(raw_spend)
  8.     gen s_jm = raw_spend / tot_pre_spend
  9.     // pre-period treated and control totals (for sample restriction)
.     by uni_id: egen pre_treat_spend = total(raw_spend * (treated == 1))
 10.     by uni_id: egen pre_ctrl_spend  = total(raw_spend * (treated == 0))
 11.     // merge EB-shrunk price betas (only present for treated markets)
.     merge m:1 category using ../external/betas/did_coefs_eb_price, ///
>         keepusing(b_eb) keep(1 3) nogen
 12.     gen exp_contrib    = cond(treated == 1, s_jm * b_eb, 0)
 13.     gen s_treat_contrib = cond(treated == 1, s_jm, 0)
 14.     gcollapse (sum) exposure = exp_contrib s_treat = s_treat_contrib ///
>               (first) pre_treat_spend pre_ctrl_spend tot_pre_spend, by(uni_id)
 15.     // sample restriction: positive pre-2013 spend in both treated and control
.     keep if pre_treat_spend > 0 & pre_ctrl_spend > 0 & !mi(exposure) & !mi(s_treat)
 16.     keep uni_id exposure s_treat tot_pre_spend
 17.     tempfile exposure_xw
 18.     save `exposure_xw'
 19.     restore
 20. 
.     // --- aggregate outcomes to uni-year ---------------------------------------
.     gen ctrl_spend  = raw_spend * (treated == 0)
 21.     gen treat_spend = raw_spend * (treated == 1)
 22.     gen ctrl_qty    = raw_qty   * (treated == 0)
 23.     gcollapse (sum) ctrl_spend treat_spend ctrl_qty raw_spend raw_qty, by(uni_id year)
 24.     rename raw_spend tot_spend
 25.     rename raw_qty   tot_qty
 26. 
.     // --- merge to exposure crosswalk (restricts sample) -----------------------
.     merge m:1 uni_id using `exposure_xw', assert(1 3) keep(3) nogen
 27. 
.     // require uni observed both pre and post 2014
.     bys uni_id: egen min_year = min(year)
 28.     bys uni_id: egen max_year = max(year)
 29.     keep if min_year < 2014 & max_year >= 2014
 30.     drop min_year max_year
 31. 
.     // outcomes (log(1+x) per spec discussion: keeps zero-spend uni-years)
.     foreach v in ctrl_spend ctrl_qty treat_spend tot_spend {
 32.         gen log1_`v' = ln(1 + `v')
 33.     }
 34. 
.     // pre-2013 uni spending for weighted regressions
.     gen wt_spend = tot_pre_spend
 35. 
.     label var exposure     "University exposure: sum_m s_jm * b_eb_m (treated mkts)"
 36.     label var s_treat      "Pre-2013 treated-market spending share"
 37.     label var ctrl_spend   "Spend in high-conf control markets (level)"
 38.     label var treat_spend  "Spend in high-conf treated markets (level)"
 39.     label var tot_spend    "Spend in all high-conf markets (level)"
 40.     label var ctrl_qty     "Quantity in high-conf control markets (level)"
 41.     save ../temp/uni_yr_panel, replace
 42. end

. 
. // -----------------------------------------------------------------------------
. // did: pooled difference-in-differences (single Post coefficient).
. //   y_jt = mu_j + lambda_t + beta * Post_t * Exposure_j
. //                          + gamma * Post_t * S_j  (optional)
. //   Cluster SEs at uni_id.
. // -----------------------------------------------------------------------------
. program did
  1.     use ../temp/uni_yr_panel, clear
  2.     gen post = year >= 2014
  3.     gen post_exp = post * exposure
  4.     gen post_s   = post * s_treat
  5. 
.     tempname memhold
  6.     tempfile didres
  7.     postfile `memhold' str40 outcome str20 spec str40 rhs ///
>         double b se str10 stars int N using `didres', replace
  8. 
.     foreach yvar in log1_ctrl_spend log1_ctrl_qty log1_tot_spend log1_treat_spend {
  9.         // raw (no S control)
.         reghdfe `yvar' post_exp, absorb(uni_id year) cluster(uni_id)
 10.         local N = e(N)
 11.         local b  = _b[post_exp]
 12.         local se = _se[post_exp]
 13.         local p  = 2*(1 - normal(abs(`b'/`se')))
 14.         local stars = cond(`p'<.01,"***",cond(`p'<.05,"**",cond(`p'<.1,"*","")))
 15.         post `memhold' ("`yvar'") ("raw") ("post_exp") (`b') (`se') ("`stars'") (`N')
 16. 
.         // identified (S control)
.         reghdfe `yvar' post_exp post_s, absorb(uni_id year) cluster(uni_id)
 17.         local N = e(N)
 18.         local b  = _b[post_exp]
 19.         local se = _se[post_exp]
 20.         local p  = 2*(1 - normal(abs(`b'/`se')))
 21.         local stars = cond(`p'<.01,"***",cond(`p'<.05,"**",cond(`p'<.1,"*","")))
 22.         post `memhold' ("`yvar'") ("with_S") ("post_exp") (`b') (`se') ("`stars'") (`N')
 23. 
.         // also save Post×S coefficient from the identified spec
.         local b  = _b[post_s]
 24.         local se = _se[post_s]
 25.         local p  = 2*(1 - normal(abs(`b'/`se')))
 26.         local stars = cond(`p'<.01,"***",cond(`p'<.05,"**",cond(`p'<.1,"*","")))
 27.         post `memhold' ("`yvar'") ("with_S") ("post_s") (`b') (`se') ("`stars'") (`N')
 28.     }
 29.     postclose `memhold'
 30. 
.     use `didres', clear
 31.     save ../output/estimates/uniyr_did, replace
 32.     export delimited using ../output/estimates/uniyr_did.csv, replace
 33.     list, sepby(outcome) noobs
 34. end

. 
. // -----------------------------------------------------------------------------
. // event_study: continuous-treatment event study.
. //   y_jt = mu_j + lambda_t + sum_n beta_n [1{rel=n} * Exposure_j]
. //                          + sum_n gamma_n [1{rel=n} * S_j]   (optional)
. //   rel = year - 2014, base period rel = -1 (year 2013).
. //   Cluster SEs at uni_id.
. // -----------------------------------------------------------------------------
. program event_study
  1.     foreach yvar in log1_ctrl_spend log1_ctrl_qty log1_tot_spend log1_treat_spend {
  2.         foreach spec in raw with_S {
  3.             cont_es, yvar(`yvar') spec(`spec')
  4.         }
  5.     }
  6. end

. 
. program cont_es
  1.     syntax, yvar(str) spec(str)
  2.     use ../temp/uni_yr_panel, clear
  3.     gen rel = year - 2014
  4.     qui sum rel
  5.     local rmin = r(min)
  6.     local rmax = r(max)
  7. 
.     // build event-time interactions; base = rel == -1
.     forval k = `rmin'/`rmax' {
  8.         if `k' == -1 continue
  9.         local tag = cond(`k' < 0, "n" + string(abs(`k')), string(`k'))
 10.         gen exp_`tag' = exposure * (rel == `k')
 11.         gen str_`tag' = s_treat * (rel == `k')
 12.     }
 13.     ds exp_*
 14.     local exp_terms `r(varlist)'
 15.     ds str_*
 16.     local str_terms `r(varlist)'
 17. 
.     if "`spec'" == "raw" {
 18.         reghdfe `yvar' `exp_terms', absorb(uni_id year) cluster(uni_id)
 19.     }
 20.     else {
 21.         reghdfe `yvar' `exp_terms' `str_terms', absorb(uni_id year) cluster(uni_id)
 22.     }
 23.     local Nobs = e(N)
 24. 
.     // collect coefficients
.     mat drop _all
 25.     forval k = `rmin'/`rmax' {
 26.         if `k' == -1 {
 27.             mat row = `k', 0, 0
 28.         }
 29.         else {
 30.             local tag = cond(`k' < 0, "n" + string(abs(`k')), string(`k'))
 31.             mat row = `k', _b[exp_`tag'], _se[exp_`tag']
 32.         }
 33.         mat es = nullmat(es) \ row
 34.     }
 35. 
.     preserve
 36.     clear
 37.     svmat es
 38.     rename (es1 es2 es3) (rel b se)
 39.     gen ub = b + 1.96*se
 40.     gen lb = b - 1.96*se
 41.     gen year = rel + 2014
 42.     gen yvar = "`yvar'"
 43.     gen spec = "`spec'"
 44.     export delimited using ///
>         ../output/estimates/es_`yvar'_`spec'.csv, replace
 45.     save ../temp/es_`yvar'_`spec', replace
 46. 
.     sum ub, d
 47.     local ymax = round(r(max), 0.01) + 0.01
 48.     sum lb, d
 49.     local ymin = round(r(min), 0.01) - 0.01
 50.     qui sum rel
 51.     local xmin = r(min)
 52.     local xmax = r(max)
 53. 
.     tw rcap ub lb rel if rel != -1, lcolor(ebblue%70) msize(vsmall) ///
>        || scatter b rel, mcolor(ebblue) msize(small) ///
>        || scatteri `ymax' -0.25 `ymax' 0.25, bcolor(gs12%30) recast(area) base(`ymin') ///
>        , xlab(`xmin'(1)`xmax', labsize(small)) ///
>          xtitle("Years relative to 2014", size(small)) ///
>          ytitle("Coef on rel x Exposure", size(small)) ///
>          ylab(, labsize(small)) ///
>          yline(0, lcolor(gs10) lpattern(solid)) ///
>          title("`yvar' (`spec', N=`Nobs')", size(small)) ///
>          legend(off) plotregion(margin(sides))
 54.     graph export ../output/figures/es/es_`yvar'_`spec'.pdf, replace
 55.     restore
 56. end

. 
