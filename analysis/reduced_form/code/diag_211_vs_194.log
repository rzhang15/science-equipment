  3.     preserve
  4.     use ../external/samp/`p', clear
  5.     contract athr_id
  6.     gen byte p`i' = 1
  7.     keep athr_id p`i'
  8.     save ../temp/diag_p`i', replace
  9.     restore
 10. }
