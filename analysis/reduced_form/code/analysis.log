. program main  
  1.     import delimited ../external/exposure/final_imputed_exposure, clear
  2.     rename exposure imputed
  3.     save ../temp/exposure, replace
  4. 
.     foreach s in all_jrnls top_jrnls {
  5.         cap mkdir "../output/figures/`s'" 
  6.         // r1 + r2 + public
.         restrict_samp, samp(`s') r1r2(1) public(1)
  7.         event_study, samp(`s') r1r2(1) public(1)
  8.         combine_es_graphs
  9.       /*  // r1 + r2
>         restrict_samp, samp(`s') r1r2(1) public(0)
>         event_study, samp(`s') r1r2(1) public(0)
>         // everyone
>         restrict_samp, samp(`s') r1r2(0) public(0)
>         event_study, samp(`s') r1r2(0) public(0)*/
.     }
 10. end

. 
. program restrict_samp 
  1.     syntax, samp(string) [, r1r2(int 0) public(int 0)]
  2.     local suf ""
  3.     if (`r1r2' == 1 & `public' == 0) local suf "_r1_r2"
  4.     if (`r1r2' == 1 & `public' == 1) local suf "_r1_r2_public"
  5.     use ../external/samp/athr_panel_full_year_last_`samp'`suf',clear 
  6. 
.     bys athr_id: egen min_year = min(year)
  7.     gen age = 2026-min_year + 35 
  8.     keep if min_year <= 2013
  9.     keep if inrange(year, 2009, 2019)
 10.     merge m:1 athr_id using ../temp/exposure, assert(1 2 3) keep(3) nogen
 11.     merge m:1 athr_id using ../external/real_exposure/athr_exposure, assert(1 2 3) keep(1 3) nogen
 12.     replace imputed = exposure if !mi(exposure)
 13.     drop if exposure < 0
 14.     drop if imputed < 0
 15.     sum exposure , d 
 16.     local mean : di %4.3f r(mean) 
 17.     local sd: di %4.3f r(sd) 
 18.     local p25: di %4.3f r(p25) 
 19.     local p50: di %4.3f r(p50) 
 20.     local p75: di %4.3f r(p75)
 21.     local max: di %4.3f  r(max) 
 22.     local min: di %4.3f r(min) 
 23.     sum imputed, d 
 24.     local imputed_mean : di %4.3f r(mean) 
 25.     local imputed_sd: di %4.3f r(sd) 
 26.     local imputed_p25: di %4.3f r(p25) 
 27.     local imputed_p50: di %4.3f r(p50) 
 28.     local imputed_p75: di %4.3f r(p75)
 29.     local imputed_max: di %4.3f  r(max) 
 30.     local imputed_min: di %4.3f r(min) 
 31.     tw kdensity exposure || kdensity imputed, xtitle("Exposure Measure", size(small)) ytitle("Density", size(small)) ///
>         ylab(, labsize(vsmall)) xlab(#15, labsize(vsmall)) ///
>         legend(on label(1 "FOIA PI Observed Exposure (mean = `mean', sd = `sd')") label(2 "Imputed Exposure (mean = `imputed_mean', sd = `imputed_sd')") pos(1) ring(0) size(vsmall))
 32.     graph export ../output/figures/`samp'/exposure_dist`suf'.pdf, replace
 33.     drop exposure
 34.     rename imputed exposure
 35.     gen q1 = exposure < `imputed_p25'
 36.     gen q2 = inrange(exposure , `imputed_p25', `imputed_p50')
 37.     gen q3 = inrange(exposure , `imputed_p50', `imputed_p75')
 38.     gen q4 = exposure >= `imputed_p75'
 39.     gen median = exposure >= `imputed_p50'
 40.     bys athr_id: gen num_yrs = _N
 41.     bys athr_id inst_id: gen plc_cntr = _n == 1
 42.     bys athr_id : egen num_place = total(plc_cntr)
 43.     keep if num_yrs != 1
 44.     keep if num_place == 1
 45.     gegen athr = group(athr_id)
 46.     xtset athr year
 47.     tsfill
 48.     hashsort athr year
 49.     foreach var in athr_id exposure q1 q2 q3 q4 median {
 50.         by athr: replace `var' = `var'[_n-1] if mi(`var')    
 51.     }
 52.     foreach var in cite_affl_wt ppr_cnt {
 53.         replace `var' = 0 if mi(`var')    
 54.     }
 55.     gen above_median = exposure >= `imputed_p50'
 56.     gen below_median = exposure < `imputed_p50'
 57.     gen young = age < 50
 58.     gen old = age >= 50
 59.     gen r1 = type == "r1" 
 60.     gen r2 = type == "r2" 
 61.     merge 1:1 athr_id year using ../external/coathrs/avg_coathrs, keep(1 3) assert(1 2 3) nogen
 62.     replace avg_num_coathrs = 0 if mi(avg_num_coathrs)
 63.     save ../temp/es_`samp'`suf', replace
 64. 
. end

