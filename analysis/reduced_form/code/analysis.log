. program output_tables
  1.     foreach tab in did_impact_cite_affl_wt did_ppr_cnt {
  2.     qui matrix_to_txt, saving("../output/tables/`tab'.txt") matrix(`tab') ///
>        title(<tab:`tab'>) format(%20.4f) replace
  3.     }
  4. end

