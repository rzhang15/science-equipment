. program event_study
  1.     syntax, samp(string) [, r1r2(int 0) public(int 0)]
  2.     local fes athr_id year 
  3.     local suf ""
  4.     if (`r1r2' == 1 & `public' == 0) local suf "_r1_r2"
  5.     if (`r1r2' == 1 & `public' == 1) local suf "_r1_r2_public"
  6.     use ../temp/es_`samp'`suf', replace
  7. 
.     gen rel = year - 2014 
  8.     qui sum rel, d
  9.     local abs_lag = abs(r(max))
 10.     qui sum rel, d
 11.     local abs_lead = abs(r(min))
 12.     local timeframe = max(`abs_lag', `abs_lead')
 13.     forval i = 1/`timeframe' {
 14.         gen int_lag`i' = exposure if rel == `i'
 15.         gen int_lead`i' = exposure if rel == -`i'
 16.         gen lag`i' = 1 if rel == `i'
 17.         gen lead`i' = 1 if rel == -`i'
 18.     }
 19.     gen int_lag0 = exposure if rel == 0
 20.     gen lag0 = 1 if rel == 0
 21.     ds lead* lag* int_lead* int_lag*
 22.     foreach var in `r(varlist)' {
 23.         replace `var' = 0 if mi(`var')
 24.     }
 25.     local leads
 26.     local int_leads
 27.     local lags
 28.     local int_lags
 29.     forval i = 2/`abs_lead' {
 30.         local leads lead`i' `leads'
 31.         local int_leads int_lead`i' `int_leads'
 32.     }
 33.     forval i = 0/`abs_lag' {
 34.         local lags `lags' lag`i'
 35.         local int_lags `int_lags' int_lag`i'
 36.     }
 37.     foreach v in cite_affl_wt ppr_cnt {
 38.         gen ln_`v' = ln(1+`v')
 39.     }
 40.     foreach yvar in cite_affl_wt ppr_cnt ln_cite_affl_wt ln_ppr_cnt body_affl_wt avg_num_coathrs {
 41.         if "`yvar'" == "cite_affl_wt" local var_name = "Citation Weighted Output" 
 42.         if "`yvar'" == "cite_affl_wt" local gap  1 
 43.         if "`yvar'" == "ppr_cnt" local var_name = "Publication Count" 
 44.         if "`yvar'" == "ppr_cnt" local gap 0.5 
 45.         if "`yvar'" == "avg_coathrs" local var_name = "Average Team Size" 
 46.         if "`yvar'" == "acg_coathrs" local gap 0.5 
 47. 
.         preserve
 48.         mat drop _all 
 49.         sum `yvar' if rel <= -1 & exposure > 0, d
 50.         local pre_mean : dis %4.3f r(mean)
 51.         reghdfe `yvar' `int_leads' `int_lags' int_lead1, absorb(`fes') vce(cluster athr_id)
 52.         foreach var in `int_leads' `int_lags' int_lead1 {
 53.             mat row = _b[`var'], _se[`var']
 54.             if "`var'" == "int_lead1" {
 55.                 mat row = 0,0
 56.             }
 57.             mat es = nullmat(es) \ row
 58.         }
 59.         svmat es
 60.         keep es1 es2
 61.         drop if mi(es1)
 62.         rename (es1 es2) (b se)
 63.         gen ub = b + 1.96*se
 64.         sum ub, d
 65.         local ymax =round(r(max),`gap')
 66.         gen lb = b - 1.96*se
 67.         sum lb, d
 68.         local ymin = min(-2.5,round(r(min),`gap'))
 69.         gen rel = -5 if _n == 1
 70.         replace rel = rel[_n-1]+1 if _n > 1
 71.         replace rel = rel + 1 if rel >= -1 
 72.         replace rel = -1 if rel == `abs_lag' + 1
 73.         gen year = rel + 2014
 74.         hashsort rel
 75.         tw rcap ub lb rel if rel != -1 , lcolor(ebblue%70) msize(vsmall) || ///
>           scatter b rel, mcolor(ebblue) || ///
>           scatteri `ymax' -0.25 `ymax' 0.25 , bcolor(gs12%30) recast(area) base(`ymin') ///
>           xlab(-5(1)5, labsize(vsmall)) xtitle("Relative Year", size(small)) ///
>           ytitle("`var_name'", size(small)) ylab(`ymin'(`gap')`ymax', labsize(vsmall)) ///
>           yline(0, lcolor(gs10) lpattern(solid)) ///
>           legend(on order(- "Pre-Period Avg : `pre_mean'") pos(7) ring(1) rows(2) bmargin(zero)) plotregion(margin(sides))
 76.         graph export ../output/figures/`samp'/es_`yvar'`suf'.pdf, replace
 77.         save ../temp/es_`yvar', replace
 78.         restore
 79. /*
>         preserve
>         mat drop _all 
>         *ppmlhdfe `yvar' `int_leads' `int_lags' int_lead1, absorb(`fes') vce(cluster athr_id)
>         reghdfe ln_`yvar' `int_leads' `int_lags' int_lead1, absorb(`fes') vce(cluster athr_id)
>         foreach var in `int_leads' `int_lags' int_lead1 {
>             mat row = _b[`var'], _se[`var']
>             if "`var'" == "int_lead1" {
>                 mat row = 0,0
>             }
>             mat es = nullmat(es) \ row
>         }
>          svmat es
>         keep es1 es2
>         drop if mi(es1)
>         rename (es1 es2) (b se)
>         gen ub = b + 1.96*se
>         sum ub, d
>         local ymax = round(r(max),.1)
>         gen lb = b - 1.96*se
>         sum lb, d
>         local ymin = round(r(min),.1)
>         gen rel = -5 if _n == 1
>         replace rel = rel[_n-1]+1 if _n > 1
>         replace rel = rel + 1 if rel >= -1 
>         replace rel = -1 if rel == `abs_lag' + 1
>         gen year = rel + 2014
>         hashsort rel
>         tw rcap ub lb rel if rel != -1 , lcolor(ebblue%70) msize(vsmall) || ///
>           scatter b rel, mcolor(ebblue) || ///
>         scatteri 1 -0.25 1 0.25 , bcolor(gs12%10) recast(area) base(-1) ///
>           xlab(-5(1)5, labsize(vsmall)) xtitle("Relative Year", size(small)) ///
>           ytitle("`var_name'", size(small)) ylab(-1(.2)1, labsize(vsmall)) ///
>           yline(0, lcolor(gs10) lpattern(solid))  legend(off) plotregion(margin(sides))
>         graph export ../output/figures/`samp'/es_ln_`yvar'`suf'.pdf, replace
>         save ../temp/es_ln_`yvar', replace
>         restore*/
. 
.         // heterogeneity by author & inst characteristics        
.         foreach cond in young old r1 r2 above_median below_median {
 80.             sum `yvar' if rel <= -1 & exposure > 0 & `cond' == 1, d
 81.             local pre_mean : dis %4.3f r(mean)
 82.             preserve
 83.             mat drop _all 
 84.             reghdfe `yvar' `int_leads' `int_lags' int_lead1 if `cond' == 1, absorb(`fes') vce(cluster athr_id)
 85.             foreach var in `int_leads' `int_lags' int_lead1 {
 86.                 mat row = _b[`var'], _se[`var']
 87.                 if "`var'" == "int_lead1" {
 88.                     mat row = 0,0
 89.                 }
 90.                 mat es = nullmat(es) \ row
 91.             }
 92.             svmat es
 93.             keep es1 es2
 94.             drop if mi(es1)
 95.             rename (es1 es2) (b se)
 96.             gen ub = b + 1.96*se
 97.             sum ub, d
 98.             local ymax = round(r(max),`gap')
 99.             gen lb = b - 1.96*se
100.             sum lb, d
101.             local ymin =  round(r(min),`gap')
102.             gen rel = -5 if _n == 1
103.             replace rel = rel[_n-1]+1 if _n > 1
104.             replace rel = rel + 1 if rel >= -1 
105.             replace rel = -1 if rel == `abs_lag' + 1
106.             gen year = rel + 2014
107.             hashsort rel
108.             tw rcap ub lb rel if rel != -1 , lcolor(ebblue%70) msize(vsmall) || ///
>               scatter b rel, mcolor(ebblue) || ///
>             scatteri `ymax' -0.25 `ymax' 0.25 , bcolor(gs12%30) recast(area) base(`ymin') ///
>               xlab(-5(1)5, labsize(vsmall)) xtitle("Relative Year", size(small)) ///
>               ytitle("`var_name'", size(small)) ylab(`ymin'(`gap')`ymax', labsize(vsmall)) ///
>               legend(on order(- "Pre-Period Avg : `pre_mean'") pos(7) ring(1) rows(2) bmargin(zero)) /// 
>               yline(0, lcolor(gs10) lpattern(solid)) plotregion(margin(sides))
109.             graph export ../output/figures/`samp'/es_`yvar'`suf'_`cond'.pdf, replace
110.             save ../temp/es_`yvar'`suf'_`cond', replace
111.             restore
112.         } 
113.        
.         // hetoregeneity by exposure quartiles
.         forval i = 1/4 {
114.             preserve
115.             mat drop _all 
116.             reghdfe `yvar' `int_leads' `int_lags' int_lead1 if q`i' == 1, absorb(`fes') vce(cluster athr_id)
117.             foreach var in `int_leads' `int_lags' int_lead1 {
118.                 mat row = _b[`var'], _se[`var']
119.                 if "`var'" == "int_lead1" {
120.                     mat row = 0,0
121.                 }
122.                 mat es = nullmat(es) \ row
123.             }
124.             svmat es
125.             keep es1 es2
126.             drop if mi(es1)
127.             rename (es1 es2) (b se)
128.             gen ub = b + 1.96*se
129.             sum ub, d
130.             local ymax = round(r(max),`gap')
131.             gen lb = b - 1.96*se
132.             sum lb, d
133.             local ymin =  round(r(min),`gap')
134.             gen rel = -5 if _n == 1
135.             replace rel = rel[_n-1]+1 if _n > 1
136.             replace rel = rel + 1 if rel >= -1 
137.             replace rel = -1 if rel == `abs_lag' + 1
138.             gen year = rel + 2014
139.             hashsort rel
140.             tw rcap ub lb rel if rel != -1 , lcolor(ebblue%70) msize(vsmall) || ///
>               scatter b rel, mcolor(ebblue) || ///
>             scatteri `ymax' -0.25 `ymax' 0.25 , bcolor(gs12%30) recast(area) base(`ymin') ///
>               xlab(-5(1)5, labsize(vsmall)) xtitle("Relative Year", size(small)) ///
>               ytitle("`var_name'", size(small)) ylab(`ymin'(`gap')`ymax', labsize(vsmall)) ///
>               yline(0, lcolor(gs10) lpattern(solid)) legend(off) plotregion(margin(sides))
141.             graph export ../output/figures/`samp'/es_`yvar'_q`i'`suf'.pdf, replace
142.             save ../temp/es_`yvar'_q`i', replace
143.             restore
144.         } 
145.     }
146. end

