. program combine_es_graphs
  1.     foreach yvar in cite_affl_wt ppr_cnt ln_cite_affl_wt ln_ppr_cnt body_affl_wt avg_num_coathrs {
  2.         if "`yvar'" == "cite_affl_wt" local var_name = "Citation Weighted Output" 
  3.         if "`yvar'" == "cite_affl_wt" local gap  1 
  4.         if "`yvar'" == "ppr_cnt" local var_name = "Publication Count" 
  5.         if "`yvar'" == "ppr_cnt" local gap 0.5 
  6.         if "`yvar'" == "avg_coathrs" local var_name = "Average Team Size" 
  7.         if "`yvar'" == "acg_coathrs" local gap 0.5 
  8.          if "`yvar'" == "cite_affl_wt" local var_name = "Citation Weighted Output"
  9.         use "../temp/es_`yvar'_q1", replace                                         
 10.         gen group = "q1"                                                                             
 11.         replace rel = rel - 0.4                                                                         
 12.         sum b if group == "q1" & rel > 0                                                             
 13.         local q1_mean : dis %4.3f r(mean)                                                            
 14.         append using ../temp/es_`yvar'_q2
 15.         replace group = "q2" if mi(group)                                                            
 16.         replace rel = rel - 0.25 if group == "q2"                                                                         
 17.         sum b if group == "q2" & rel > 0                                                             
 18.         local q2_mean : dis %4.3f r(mean)                                                            
 19.         append using ../temp/es_`yvar'_q3
 20.         replace group = "q3" if mi(group)                                                            
 21.         replace rel = rel - 0.1 if group == "q3"                                                                         
 22.         sum b if group == "q3" & rel > 0                                                             
 23.         local q3_mean : dis %4.3f r(mean)                                                            
 24.         append using ../temp/es_`yvar'_q4
 25.         replace group = "q4" if mi(group)
 26.         replace rel = rel + 0.05 if group == "q4"                                                                         
 27.         sum b if group == "q4" & rel > 0                                                             
 28.         local q4_mean : dis %4.3f r(mean)                                                            
 29.         tw rcap ub lb rel if rel != -1.4 & group == "q1",  lcolor(lavender%70) msize(small) || ///   
>            scatter b rel if group == "q1", mcolor(lavender%70) msize(small) || ///                   
>            rcap ub lb rel if rel != -1.25 & group == "q2",  lcolor(orange%70) msize(small) || ///     
>            scatter b rel if group == "q2", mcolor(orange%70) msymbol(smdiamond) msize(small) ||  ///  
>            rcap ub lb rel if rel != -1.1 & group == "q3",  lcolor(dkgreen%70) msize(small) || ///     
>            scatter b rel if group == "q3", mcolor(green%70) msymbol(smdiamond) msize(small)|| ///  
>            rcap ub lb rel if rel != -.95 & group == "q4",  lcolor(cranberry%70) msize(small) || ///     
>            scatter b rel if group == "q4", mcolor(red%70) msymbol(smdiamond) msize(small)  ///  
>            xlab(-5(1)5, labsize(small)) ylab(#8, labsize(vsmall)) ///                         
>               yline(0, lcolor(black) lpattern(solid)) ///                                               
>               legend(on order(2 "Q1 Exposed (Post Period Avg: `q1_mean')" 4 "Q2 Exposed (Post Period Avg: `q2_mean')" 6 "Q3 Exposed (Post Period Avg: `q3_mean')" 8 "Q4 Exposed (Post Period Avg: `q4_mean')") pos(7) ring(1) size(small) region(fcolor(none)
> )) xtitle("Relative Year", size(small)) ytitle("`var_name'", size(small)) plotregion(margin(sides))
 30.         graph export ../output/figures/`samp'/es_`yvar'_split`suf'.pdf, replace     
 31. 
.         use "../temp/es_`yvar'_r1_r2_public_below_median", replace                                         
 32.         gen group = "below"                                                                             
 33.         replace rel = rel - 0.1                                                                         
 34.         sum b if group == "below" & rel > 0                                                             
 35.         local below_mean : dis %4.3f r(mean)                                                            
 36.         append using ../temp/es_`yvar'_r1_r2_public_above_median
 37.         replace group = "above" if mi(group)                                                            
 38.         sum b if group == "above" & rel > 0                                                             
 39.         local above_mean : dis %4.3f r(mean)                                                            
 40.         tw rcap ub lb rel if rel != -1.1 & group == "below",  lcolor(lavender%70) msize(small) || ///   
>            scatter b rel if group == "below", mcolor(lavender%70) msize(small) || ///                   
>            rcap ub lb rel if rel != -1 & group == "above",  lcolor(dkorange%70) msize(small) || ///     
>            scatter b rel if group == "above", mcolor(dkorange%70) msymbol(smdiamond) msize(small)  ///  
>            xlab(-5(1)5, labsize(small)) ylab(#8, labsize(small)) ///                         
>               yline(0, lcolor(black) lpattern(solid)) ///                                               
>               legend(on order(2 "Below Median Exposure (Post Period Avg: `below_mean')" 4 "Above Median Exposure (Post Period Avg: `above_mean')" ) pos(11) ring(0) size(small) region(fcolor(none))) xtitle("Relative Year", size(small)) ytitle("`var_name'
> ", size(small)) plotregion(margin(sides))
 41.         graph export ../output/figures/`samp'/es_`yvar'_split`suf'.pdf, replace     
 42.     }
 43. end

