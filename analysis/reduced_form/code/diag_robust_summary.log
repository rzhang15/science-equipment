. local samp all_jrnls

. local suf  _r1_r2_public

. 
. program summ_es
  1.     syntax, fpath(string) tag(string)
  2.     use "`fpath'", clear
  3.     qui sum rel
  4.     if r(N) == 0 {
  5.         di as text "`tag': (empty)"
  6.         exit
  7.     }
  8.     qui sum b if rel < -1
  9.     local pre_max_b = r(max)
 10.     local pre_min_b = r(min)
 11.     local pre_mean_b = r(mean)
 12.     qui sum b if rel >= 0 & rel <= 5
 13.     local post_mean_b = r(mean)
 14.     qui sum se if rel >= 0 & rel <= 5
 15.     local post_mean_se = r(mean)
 16.     qui count if rel >= 0 & (lb > 0 | ub < 0)
 17.     local n_post_signif = r(N)
 18.     qui count if rel < -1 & (lb > 0 | ub < 0)
 19.     local n_pre_signif = r(N)
 20.     di as text "`tag': pre_mean=" %5.3f `pre_mean_b' " pre_minmax=[" %5.3f
>  `pre_min_b' "," %5.3f `pre_max_b' "] post_mean=" %5.3f `post_mean_b' " post_
> mean_se=" %5.3f `post_mean_se' " n_pre_signif=`n_pre_signif' n_post_signif=`n
> _post_signif'"
 21. end

. 
