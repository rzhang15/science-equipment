. local samp all_jrnls

. local suf  _r1_r2_public

. local fes  athr_id year

. 
. program summ_grp
  1.     syntax, hi(string) lo(string) tag(string)
  2.     foreach grp in `hi' `lo' {
  3.         local b_post = 0
  4.         local n_post = 0
  5.         local b_pre  = 0
  6.         local n_pre  = 0
  7.         forval k = 0/5 {
  8.             local b = _b[int_lag`k'_`grp']
  9.             local b_post = `b_post' + `b'
 10.             local n_post = `n_post' + 1
 11.         }
 12.         forval k = 2/4 {
 13.             local b = _b[int_lead`k'_`grp']
 14.             local b_pre = `b_pre' + `b'
 15.             local n_pre = `n_pre' + 1
 16.         }
 17.         local post_mean = `b_post' / `n_post'
 18.         local pre_mean = `b_pre' / `n_pre'
 19.         di as text "`tag' `grp': pre_mean=" %6.3f `pre_mean' " post_mean="
>  %6.3f `post_mean'
 20.     }
 21. end

. 
. foreach yvar in ppr_cnt cite_affl_wt {
  2.     di as text "============================================"
  3.     di as text "==== `yvar' ===="
  4.     di as text "============================================"
  5. 
.     foreach pair in "high_pre_ppr low_pre_ppr" "high_grants low_grants" {
  6.         local hi : word 1 of `pair'
  7.         local lo : word 2 of `pair'
  8. 
.         di as text "---- heterogeneous ES (base specification): `hi' vs `lo' 
> ----"
  9.         use ../temp/es_`samp'`suf', clear
 10.         cap drop rel int_lead* int_lag*
 11.         gen rel = year - 2014
 12.         qui sum rel
 13.         local abs_lag  = abs(r(max))
 14.         local abs_lead = abs(r(min))
 15.         forval i = 1/`abs_lead' {
 16.             gen int_lead`i' = exposure if rel == -`i'
 17.         }
 18.         forval i = 1/`abs_lag' {
 19.             gen int_lag`i'  = exposure if rel == `i'
 20.         }
 21.         gen int_lag0 = exposure if rel == 0
 22.         ds int_lead* int_lag*
 23.         foreach var in `r(varlist)' {
 24.             replace `var' = 0 if mi(`var')
 25.         }
 26.         foreach grp in `hi' `lo' {
 27.             forval i = 1/`abs_lead' {
 28.                 gen int_lead`i'_`grp' = int_lead`i' * `grp'
 29.             }
 30.             forval i = 0/`abs_lag' {
 31.                 gen int_lag`i'_`grp' = int_lag`i' * `grp'
 32.             }
 33.         }
 34.         local leads_hi
 35.         local lags_hi
 36.         local leads_lo
 37.         local lags_lo
 38.         forval i = 2/`abs_lead' {
 39.             local leads_hi `leads_hi' int_lead`i'_`hi'
 40.             local leads_lo `leads_lo' int_lead`i'_`lo'
 41.         }
 42.         forval i = 0/`abs_lag' {
 43.             local lags_hi `lags_hi' int_lag`i'_`hi'
 44.             local lags_lo `lags_lo' int_lag`i'_`lo'
 45.         }
 46.         cap noi reghdfe `yvar' `leads_hi' `lags_hi' `leads_lo' `lags_lo' /
> //
>                 int_lead1_`hi' int_lead1_`lo', absorb(`fes') vce(cluster athr
> _id)
 47.         summ_grp, hi(`hi') lo(`lo') tag("HET")
 48. 
.         di as text "---- group-absorbed ES (within-group exposure only): `hi'
>  vs `lo' ----"
 49.         forval i = 2/`abs_lead' {
 50.             cap drop g1rel_lead`i'
 51.             gen g1rel_lead`i' = (rel == -`i') * `hi'
 52.         }
 53.         forval i = 0/`abs_lag' {
 54.             cap drop g1rel_lag`i'
 55.             gen g1rel_lag`i'  = (rel == `i')  * `hi'
 56.         }
 57.         local g1rel_leads
 58.         local g1rel_lags
 59.         forval i = 2/`abs_lead' {
 60.             local g1rel_leads `g1rel_leads' g1rel_lead`i'
 61.         }
 62.         forval i = 0/`abs_lag' {
 63.             local g1rel_lags `g1rel_lags' g1rel_lag`i'
 64.         }
 65.         cap noi reghdfe `yvar' `leads_hi' `lags_hi' `leads_lo' `lags_lo' /
> //
>                 int_lead1_`hi' int_lead1_`lo' `g1rel_leads' `g1rel_lags', ///
>                 absorb(`fes') vce(cluster athr_id)
 66.         summ_grp, hi(`hi') lo(`lo') tag("ABS")
 67. 
.         // also print the absorbed-trend (g1's common trend relative to g2)
.         local b_post = 0
 68.         forval k = 0/5 {
 69.             local b_post = `b_post' + _b[g1rel_lag`k']
 70.         }
 71.         local b_pre = 0
 72.         forval k = 2/4 {
 73.             local b_pre = `b_pre' + _b[g1rel_lead`k']
 74.         }
 75.         local post_mean = `b_post' / 6
 76.         local pre_mean  = `b_pre' / 3
 77.         di as text "    --> absorbed common trend (`hi' minus `lo'): pre_m
> ean=" %6.3f `pre_mean' " post_mean=" %6.3f `post_mean'
 78.     }
 79. }
