. do diagnose_extremes.do 

. set more off

. clear all

. capture log close

. program drop _all

. set scheme modern

. preliminaries

. version 17

. 
. program main
  1.     build_diagnostics
  2. end

. 
. program build_diagnostics
  1.     // Build per-category diagnostics for the 20 most extreme placebo coefficients.
.     // Output: ../output/extreme_placebo_diagnostics.csv
. 
.     // 1. Collapse placebo coefs to one row per category (mean, sd, n_iters)
.     use ../output/did_coefs_placebo, clear
  2.     gcollapse (mean) mean_b = b (sd) sd_b = b (count) n_iters_treated = b, by(category)
  3. 
.     // 2. Tag the 20 categories of interest (top 10 + bottom 10 by mean_b)
.     gsort -mean_b
  4.     gen rank_high = _n
  5.     gsort mean_b
  6.     gen rank_low = _n
  7.     gen flagged_top = rank_high <= 10
  8.     gen flagged_bottom = rank_low <= 10
  9.     gen flagged = flagged_top | flagged_bottom
 10. 
.     tempfile coefs
 11.     save `coefs'
 12. 
.     // 3. Compute pre-trend slope and post-trend delta from the AGGREGATE panel
.     //    (category × year, weighted across unis). Mirrors match_placebo.R:49-59.
.     use ../../../derived/first_stage/make_mkt_panel/output/category_yr_tfidf.dta, clear
 13. 
.     // Pre-trend slope: regression of avg_log_price on year, 2010-2013
.     preserve
 14.     keep if year <= 2013
 15.     gen year_c = year - 2012
 16.     statsby pretrend_slope = _b[year_c], by(category) clear: regress avg_log_price year_c
 17.     tempfile slopes
 18.     save `slopes'
 19.     restore
 20. 
.     // Post-2014 delta: mean log_raw_price 2015-2017 minus mean 2011-2013
.     preserve
 21.     gen pre_block  = inrange(year, 2011, 2013)
 22.     gen post_block = inrange(year, 2015, 2017)
 23.     keep if pre_block | post_block
 24.     gcollapse (mean) log_raw_price [aw=spend_2013], by(category pre_block post_block)
 25.     gen which = "pre" if pre_block == 1
 26.     replace which = "post" if post_block == 1
 27.     keep category log_raw_price which
 28.     greshape wide log_raw_price, i(category) j(which) string
 29.     gen posttrend_delta = log_raw_pricepost - log_raw_pricepre
 30.     keep category posttrend_delta
 31.     tempfile deltas
 32.     save `deltas'
 33.     restore
 34. 
.     // Category-level metadata: support/precision/recall, total spend, treated, bad_control
.     use ../../../derived/first_stage/make_mkt_panel/output/category_yr_tfidf.dta, clear
 35.     gcollapse (firstnm) support precision recall treated tier1 tier2 tier3 spend_2013 ///
>               (sum) total_spend = raw_spend total_obs_cnt = obs_cnt, by(category)
 36.     merge 1:1 category using `slopes',  nogen
 37.     merge 1:1 category using `deltas',  nogen
 38. 
.     // 4. Per-category n_unis from the uni panel
.     preserve
 39.     use ../../../derived/first_stage/make_mkt_panel/output/uni_category_yr_tfidf.dta, clear
 40.     gcollapse (firstnm) anything = treated, by(category uni_id)
 41.     gcollapse (count) n_unis = anything, by(category)
 42.     tempfile unicount
 43.     save `unicount'
 44.     restore
 45.     merge 1:1 category using `unicount', nogen
 46. 
.     // 5. Bad-control flag from the documentation CSV
.     preserve
 47.     import delimited using ../../../derived/first_stage/select_categories/output/bad_control_documentation.csv, clear stringcols(_all) varnames(1)
 48.     keep category bad_control bad_control_reason
 49.     tempfile bc
 50.     save `bc'
 51.     restore
 52.     merge 1:1 category using `bc', nogen keep(1 3)
 53.     replace bad_control = "0" if bad_control == ""
 54. 
.     // 6. Sibling flag: count of OTHER categories sharing same " - " prefix
.     gen has_dash = strpos(category, " - ") > 0
 55.     gen prefix = ""
 56.     qui replace prefix = substr(category, 1, strpos(category, " - ") - 1) if has_dash == 1
 57.     bys prefix: gen n_in_prefix = _N if prefix != ""
 58.     gen sibling_within_pool = (n_in_prefix - 1) if prefix != ""
 59.     replace sibling_within_pool = 0 if mi(sibling_within_pool)
 60.     drop has_dash n_in_prefix prefix
 61. 
.     // 7. Merge placebo coefs back
.     merge 1:1 category using `coefs', keep(2 3) nogen
 62.     keep if flagged == 1
 63. 
.     // 8. Format and export
.     gsort -mean_b
 64.     order category mean_b sd_b n_iters_treated total_spend total_obs_cnt n_unis ///
>           support precision recall treated bad_control bad_control_reason ///
>           pretrend_slope posttrend_delta sibling_within_pool flagged_top flagged_bottom
 65. 
.     label var mean_b           "Mean placebo DiD coef across iters"
 66.     label var sd_b             "SD of placebo DiD coef across iters"
 67.     label var n_iters_treated  "# placebo iters this cat drew treatment"
 68.     label var total_spend      "Total raw spend across all years/unis"
 69.     label var total_obs_cnt    "Total transaction count"
 70.     label var n_unis           "# distinct universities ever observing cat"
 71.     label var support          "Classifier training support"
 72.     label var precision        "Classifier precision"
 73.     label var recall           "Classifier recall"
 74.     label var treated          "Real-treated indicator (should be 0 for all)"
 75.     label var bad_control      "Already flagged as bad control (CSV)"
 76.     label var pretrend_slope   "Slope of avg_log_price on year, 2010-2013"
 77.     label var posttrend_delta  "Mean log_raw_price 2015-17 minus 2011-13"
 78.     label var sibling_within_pool "# other cats sharing same ' - ' prefix"
 79. 
.     list category mean_b sd_b n_iters_treated support precision recall total_obs_cnt n_unis ///
>          pretrend_slope posttrend_delta sibling_within_pool, sep(0) noobs abbrev(40)
 80. 
.     export delimited using ../output/extreme_placebo_diagnostics.csv, replace
 81. end

. 
